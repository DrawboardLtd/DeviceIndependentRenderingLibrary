<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <IsAotCompatible>true</IsAotCompatible>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <VersionPrefix>5.1.0</VersionPrefix>
    <AssemblyVersion>5.1.0.0</AssemblyVersion>
    <PackageID>DIR.Lib</PackageID>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/drawboardltd/DeviceIndependentRenderingLibrary.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DIR.Lib.Tests" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../LICENSE" Pack="true" PackagePath="/" />
    <None Include="../../README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <!--
    SharpAstro.Fonts (managed font loader/rasterizer) is referenced via
    ProjectReference when a sibling working copy exists, so iteration on
    Phase 12 can happen in-tree. CI / package builds without the sibling
    fall through to PackageReference automatically.
  -->
  <PropertyGroup>
    <UseLocalFontsLib Condition="'$(UseLocalFontsLib)' == '' AND Exists('..\..\..\Fonts.Lib\src\SharpAstro.Fonts\SharpAstro.Fonts.csproj')">true</UseLocalFontsLib>
  </PropertyGroup>
  <ItemGroup Condition="'$(UseLocalFontsLib)' == 'true'">
    <ProjectReference Include="..\..\..\Fonts.Lib\src\SharpAstro.Fonts\SharpAstro.Fonts.csproj" />
  </ItemGroup>
  <ItemGroup Condition="'$(UseLocalFontsLib)' != 'true'">
    <PackageReference Include="SharpAstro.Fonts" />
  </ItemGroup>

  <!--
    DIR.Lib is codec-agnostic. The 4.0 release dropped its phantom dependencies
    on SharpAstro.Tiff / .Exif / .Color.Icc — those were leftover declarations
    from the Phase 1 codec extraction (commit 7190245 in the StbImageSharp repo)
    that never had matching `using` directives in DIR.Lib source. RenderToRgba
    returns an RgbaImage and callers (Console.Lib, tianwen, etc.) own the
    choice of encoder. Consumers that need TIFF / Png / JPEG / ICC declare
    those packages directly themselves.
  -->

  <!--
    SharpAstro.LALR.CC drives the math-mode LaTeX grammar plus the markdown
    inline + block grammars baked into DIR.Lib.Markdown. The Roslyn source
    generator runs at build time on grammars/*.lalr.yaml and emits the
    Latex / MarkdownInline / MarkdownBlock partial classes into this
    assembly — no runtime parser construction, AOT-clean. Generated
    namespace tracks csproj RootNamespace (defaults to `DIR.Lib`); the
    hand-written AST records, visitors, and Mhchem state machine live in
    the `DIR.Lib.Markdown` sub-namespace alongside.
  -->
  <PropertyGroup>
    <UseLocalLalrCc Condition="'$(UseLocalLalrCc)' == '' AND Exists('..\..\..\LALR.CC\LALR.CC\LALR.CC.csproj')">true</UseLocalLalrCc>
  </PropertyGroup>
  <ItemGroup Condition="'$(UseLocalLalrCc)' == 'true'">
    <ProjectReference Include="..\..\..\LALR.CC\LALR.CC\LALR.CC.csproj" />
    <ProjectReference Include="..\..\..\LALR.CC\LALR.CC.SourceGenerators\LALR.CC.SourceGenerators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>
  <ItemGroup Condition="'$(UseLocalLalrCc)' != 'true'">
    <PackageReference Include="SharpAstro.LALR.CC" />
  </ItemGroup>

  <!--
    YamlDotNet is consumed only by the LALR.CC source generator (build-time)
    to parse grammars/*.lalr.yaml. PrivateAssets="all" keeps it out of the
    runtime closure and out of the published package; the Analyzer item
    passes its netstandard2.0 DLL into the analyzer load context next to
    the source generator. The generated parser classes have no YamlDotNet
    references.
  -->
  <ItemGroup>
    <PackageReference Include="YamlDotNet" GeneratePathProperty="true" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <Analyzer Include="$(PkgYamlDotNet)\lib\netstandard2.0\YamlDotNet.dll" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="grammars\latex.lalr.yaml" Link="latex.lalr.yaml" />
    <AdditionalFiles Include="grammars\markdown-inline.lalr.yaml" Link="markdown-inline.lalr.yaml" />
    <AdditionalFiles Include="grammars\markdown-block.lalr.yaml" Link="markdown-block.lalr.yaml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
